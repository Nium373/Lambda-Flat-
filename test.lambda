# Lambda Flat test suite

total = 0;
passed = 0;

function assert(condition, message) {
    total = total + 1;
    if (condition) {
        passed = passed + 1;
        print("  PASS: " + message);
    } else {
        print("  FAIL: " + message);
    }
}

# ==============================
print("");
print("== 1. Arithmetic ==");

assert(1 + 2 = 3, "1 + 2 = 3");
assert(5 - 3 = 2, "5 - 3 = 2");
assert(4 * 3 = 12, "4 * 3 = 12");
assert(10 / 2 = 5, "10 / 2 = 5");
assert(10 % 3 = 1, "10 % 3 = 1");
assert(1 + 2 * 3 = 7, "precedence: 1 + 2 * 3 = 7");
assert((1 + 2) * 3 = 9, "parens: (1 + 2) * 3 = 9");
assert(-5 = -5, "unary minus");
assert(-(3 + 2) = -5, "unary minus with parens");

# ==============================
print("");
print("== 2. Strings ==");

assert("hello" + " world" = "hello world", "string concat");
assert(str(42) = "42", "str() number");
assert(str(true) = "true", "str() bool");
assert(str(nil) = "nil", "str() nil");

# ==============================
print("");
print("== 3. Comparisons ==");

assert(5 > 3, "5 > 3");
assert(3 >= 3, "3 >= 3");
assert(2 < 5, "2 < 5");
assert(5 <= 5, "5 <= 5");
assert(5 = 5, "5 = 5");
assert(5 != 3, "5 != 3");
assert("abc" = "abc", "string =");
assert("abc" != "def", "string !=");
assert(true != false, "true != false");

# ==============================
print("");
print("== 4. Extreme comparisons ==");

assert(100 >> 10, "100 >> 10");
assert(1000 >> 10, "1000 >> 10");
assert(10 !>> 10, "10 !>> 10");
assert(10 << 100, "10 << 100");
assert(10 !<< 10, "10 !<< 10");
assert(10 !> 10, "10 !> 10");
assert(10 !< 10, "10 !< 10");

# ==============================
print("");
print("== 5. Boolean / short-circuit ==");

assert(true and true, "true and true");
assert(!(false and true), "false and true");
assert(true or false, "true or false");
assert(!(false or false), "false or false");
assert(!true = false, "!true");
assert(not false = true, "not false");

# AND short-circuit: false and X must NOT evaluate X
side = 0;
function setSide() {
    side = 1;
    return true;
}
false and setSide();
assert(side = 0, "AND short-circuits on false");

# OR short-circuit: true or X must NOT evaluate X
side = 0;
true or setSide();
assert(side = 0, "OR short-circuits on true");

# ==============================
print("");
print("== 6. If/else ==");

result = "";
if (true) {
    result = "then";
} else {
    result = "else";
}
assert(result = "then", "if true");

result = "";
if (false) {
    result = "then";
} else {
    result = "else";
}
assert(result = "else", "if false");

result = "";
if (false) {
    result = "a";
} else if (true) {
    result = "b";
} else {
    result = "c";
}
assert(result = "b", "else if");

# elif
result = "";
if (false) {
    result = "a";
} elif (true) {
    result = "b";
} else {
    result = "c";
}
assert(result = "b", "elif matches");

result = "";
if (false) {
    result = "a";
} elif (false) {
    result = "b";
} elif (true) {
    result = "c";
} else {
    result = "d";
}
assert(result = "c", "elif chain third branch");

result = "";
if (false) {
    result = "a";
} elif (false) {
    result = "b";
} else {
    result = "c";
}
assert(result = "c", "elif falls through to else");

# ==============================
print("");
print("== 7. While loops ==");

i = 0;
while (i < 3) {
    i = i + 1;
}
assert(i = 3, "while counts");

i = 0;
while (i < 10) {
    i = i + 1;
    if (i = 3) {
        break;
    }
}
assert(i = 3, "break in while");

i = 0;
sum = 0;
while (i < 5) {
    i = i + 1;
    if (i = 3) {
        continue;
    }
    sum = sum + i;
}
assert(sum = 12, "continue in while skips 3 (1+2+4+5=12)");

# ==============================
print("");
print("== 8. For loops ==");

sum = 0;
for (j = 1; j <= 4; j = j + 1) {
    sum = sum + j;
}
assert(sum = 10, "for loop sums 1..4");

sum = 0;
for (j = 1; j <= 10; j = j + 1) {
    if (j = 3) {
        break;
    }
    sum = sum + j;
}
assert(sum = 3, "break in for (1+2)");

sum = 0;
for (j = 1; j <= 5; j = j + 1) {
    if (j = 3) {
        continue;
    }
    sum = sum + j;
}
assert(sum = 12, "continue in for skips 3 (1+2+4+5=12)");

# ==============================
print("");
print("== 9. Switch/case ==");

result = "";
switch (2) {
    case 1 {
        result = "one";
    }
    case 2 {
        result = "two";
    }
    default {
        result = "other";
    }
}
assert(result = "two", "switch matches");

result = "";
switch (99) {
    case 1 {
        result = "one";
    }
    default {
        result = "default";
    }
}
assert(result = "default", "switch default");

result = "";
switch (99) {
    case 1 {
        result = "one";
    }
    case 2 {
        result = "two";
    }
}
assert(result = "", "switch no match");

# ==============================
print("");
print("== 10. Arrays ==");

arr = [1, 2, 3];
assert(arr.size() = 3, "arr.size()");
assert(arr[0] = 1, "index 0");
assert(arr[2] = 3, "index 2");

arr = [];
arr.push(10);
arr.push(20);
assert(arr.size() = 2, "push size");
assert(arr[0] = 10, "push value");

v = arr.pop();
assert(v = 20, "pop value");
assert(arr.size() = 1, "after pop size");

# ==============================
print("");
print("== 12. Functions ==");

function add(a, b) {
    return a + b;
}
assert(add(3, 4) = 7, "add");

function factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}
assert(factorial(5) = 120, "factorial(5)");

function fib(n) {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}
assert(fib(10) = 55, "fib(10)");

# Closures
function makeCounter() {
    count = 0;
    function increment() {
        count = count + 1;
        return count;
    }
    return increment;
}
counter = makeCounter();
assert(counter() = 1, "closure 1st call");
assert(counter() = 2, "closure 2nd call");
assert(counter() = 3, "closure 3rd call");

# ==============================
print("");
print("== 13. Compound assignment ==");

n = 10;
n += 5;
assert(n = 15, "n += 5");

n -= 3;
assert(n = 12, "n -= 3");

n *= 2;
assert(n = 24, "n *= 2");

n /= 4;
assert(n = 6, "n /= 4");

n %= 4;
assert(n = 2, "n %= 4");

s = "hello";
s += " world";
assert(s = "hello world", "string +=");

