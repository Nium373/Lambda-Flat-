# ==============================
print("");
print("== 17. Edge cases ==");

assert(nil != false, "nil != false");
assert(nil != 0, "nil != 0");
assert(!nil, "!nil");
assert(nil = nil, "nil = nil");

empty = [];
assert(empty.size() = 0, "empty array");

# ==============================
print("");
print("== 18. New operators ==");

assert(2 ** 10 = 1024, "** power");
assert(2 ** 3 ** 2 = 512, "** right-assoc (2**(3**2) = 2**9 = 512)");
assert(3 * 2 ** 4 = 48, "** binds tighter than * (3*16=48)");

assert(7 // 3 = 2, "// integer division");
assert(10 // 4 = 2, "// 10//4=2");
assert((-7) // 3 = -2, "// negative truncated toward zero");

assert(1..5 = [1, 2, 3, 4, 5], ".. range ascend");
assert(5..1 = [5, 4, 3, 2, 1], ".. range descend");

i = 0;
i++;
assert(i = 1, "++ postfix increment value");
i = 5;
result = i++;
assert(result = 5, "++ postfix returns old value");
assert(i = 6, "++ postfix updates variable");

i = 10;
i--;
assert(i = 9, "-- postfix decrement value");
i = 5;
result = i--;
assert(result = 5, "-- postfix returns old value");
assert(i = 4, "-- postfix updates variable");

# ==============================
print("");
print("== 19. String + number auto-conversion ==");

assert("value: " + 42 = "value: 42", "string + number");
assert(42 + " is the answer" = "42 is the answer", "number + string");
assert("1+2=" + (1+2) + "!" = "1+2=3!", "expression in concat");
assert("" + 0 = "0", "empty string + number");
assert(0 + "" = "0", "number + empty string");

s = "count: ";
s += 5;
assert(s = "count: 5", "string +=");
t = 5;
t += " items";
assert(t = "5 items", "number +=");

# ==============================
print("");
print("== 20. Multi-statement lines ==");

a = 1; b = 2; c = 3;
assert(a = 1 and b = 2 and c = 3, "semicolons on one line");

d = 10 e = 20 f = 30
assert(d = 10 and e = 20 and f = 30, "no semicolons on one line");

# ==============================
print("");
print("== 21. & and | operators ==");

assert(true & true, "& true and true");
assert(!(true & false), "& true and false");
assert(!(false & true), "& false and true");
assert(!(false & false), "& false and false");
assert(true | true, "| true or true");
assert(true | false, "| true or false");
assert(false | true, "| false or true");
assert(!(false | false), "| false or false");

y = 1;
if (false & (y=2)) { }
assert(y = 1, "& short-circuit: y unchanged");

y = 1;
if (true  | (y=2)) { }
assert(y = 1, "| short-circuit: y unchanged");

print("");
print("== 21b. || (XOR) operator ==");

assert(!(true || true), "|| true xor true = false");
assert(true || false, "|| true xor false = true");
assert(false || true, "|| false xor true = true");
assert(!(false || false), "|| false xor false = false");
assert(true || true || true, "|| associative: 3 trues = true");
assert(!(false || false || false), "|| associative: 3 falses = false");
assert(!(5 || 3), "|| numbers: 5 xor 3 -> truthy xor truthy -> false");

print("");
print("== 22. ~ !~ in between operators ==");

assert(1.0 ~ 1.0, "~ equal numbers");
assert(0.1 + 0.2 ~ 0.3, "~ float tolerance");
assert(!(1.0 ~ 2.0), "~ unequal numbers");
assert(1000000 ~ 1000100, "~ large numbers within 0.1%");
assert(!(1000000 ~ 1010000), "~ large numbers beyond 0.1%");
assert("hi" ~ "hi", "~ string equal");
assert(!("hi" ~ "bye"), "~ string unequal");
assert(1.0 !~ 2.0, "!~ unequal numbers");
assert(!(1.0 !~ 1.0), "!~ equal numbers false");

assert(3 in 1..5, "in 3 in 1..5");
assert(!(6 in 1..5), "in 6 not in 1..5");
assert(1 in 1..1, "in single element range");
assert(!(1.5 in 1..5), "in 1.5 not in integer range");
assert(5 in 5..1, "in descending range");

assert(1.5 between 1..5, "between 1.5 between 1..5");
assert(1 between 1..5, "between lower bound");
assert(5 between 1..5, "between upper bound");
assert(!(0 between 1..5), "between below range");
assert(!(6 between 1..5), "between above range");
assert(3 between 5..1, "between descending range");

print("");
print("== 23. Classes & Objects ==");

class Animal {
    function init(name) {
        self.name = name
    }
    function speak() {
        return self.name + " makes a sound"
    }
}

class Dog extends Animal {
    function init(name, breed) {
        Animal.init(self, name)
        self.breed = breed
    }
    function speak() {
        return self.name + " barks"
    }
    function getBreed() {
        return self.breed
    }
}

a = Animal("Generic")
assert(a.speak() = "Generic makes a sound", "class method call with self")

d = Dog("Rex", "shepherd")
assert(d.speak() = "Rex barks", "inherited method override")
assert(d.getBreed() = "shepherd", "subclass own method")
assert(d.name = "Rex", "field read via dot")
assert(d.breed = "shepherd", "inherited field via dot")

class Empty {
}

e = Empty()
assert(true, "empty class instantiation")

m = Map("x", 10, "y", 20)
assert(m.x = 10, "Map() field read")
assert(m.y = 20, "Map() second field")
m.x = 99
assert(m.x = 99, "Map() field write")

